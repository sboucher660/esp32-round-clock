{
  "title": "ESP32 round clock hotkeys",
  "rules": [
    {
      "description": "ESP32 clock: Cmd+Shift+Right = next page",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_arrow",
            "modifiers": {
              "mandatory": ["command", "shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "/bin/zsh \"$HOME/Library/Application Support/esp32-round-clock/send-page.sh\" next"
            }
          ]
        }
      ]
    },
    {
      "description": "ESP32 clock: Cmd+Shift+Left = prev page",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_arrow",
            "modifiers": {
              "mandatory": ["command", "shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "/bin/zsh \"$HOME/Library/Application Support/esp32-round-clock/send-page.sh\" prev"
            }
          ]
        }
      ]
    },
    {
      "description": "ESP32 clock: Cmd+Shift+Up = rotate right",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "up_arrow",
            "modifiers": {
              "mandatory": ["command", "shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "/bin/zsh \"$HOME/Library/Application Support/esp32-round-clock/send-rotate.sh\" r"
            }
          ]
        }
      ]
    },
    {
      "description": "ESP32 clock: Cmd+Shift+Down = rotate left",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "down_arrow",
            "modifiers": {
              "mandatory": ["command", "shift"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "shell_command": "/bin/zsh \"$HOME/Library/Application Support/esp32-round-clock/send-rotate.sh\" l"
            }
          ]
        }
      ]
    }
  ]
}